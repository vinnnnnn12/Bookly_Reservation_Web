# =============================================
# Contoh Environment Variables untuk Vercel + Aiven MySQL
# JANGAN commit file .env asli ke Git — file ini cuma contoh.
# Set variabel-variabel ini di: Vercel Dashboard > Project > Settings > Environment Variables
# =============================================

# Didapat dari Aiven Console > Service Overview
DB_HOST=your-service-name.aivencloud.com
DB_PORT=12345
DB_USER=avnadmin
DB_PASS=your-aiven-password
DB_NAME=defaultdb

# Isi (contents) file ca.pem yang di-download dari Aiven Console.
# Paste seluruh isi file termasuk baris -----BEGIN CERTIFICATE----- dan -----END CERTIFICATE-----
DB_SSL_CA="-----BEGIN CERTIFICATE-----
MIIExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
...
-----END CERTIFICATE-----"
